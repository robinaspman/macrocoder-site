# GitHub OAuth App Client ID
# Create at: https://github.com/settings/developers
VITE_GITHUB_CLIENT_ID=your_github_client_id_here

# Cloudflare Worker URL
# Get this after deploying your worker
VITE_WORKER_URL=https://macrocoder-worker.your-subdomain.workers.dev

# ==============================================
# MacroCoder API (FastAPI on Hetzner)
# ==============================================
# The FastAPI backend URL (deployed on Hetzner)
VITE_MACROCODER_URL=https://api.macrocoder.dev

# Your Hetzner Cloud API Key
# Get from: https://console.hetzner.cloud/
VITE_MACROCODER_API_KEY=your_hetzner_api_key_here